#!/usr/bin/env bash
#
# pre-commit hook — fast gates only: secret scan + rustfmt check.
# Heavier checks (clippy, tests) live in pre-push.
# Install:  git config core.hooksPath .githooks
# Skip:     git commit --no-verify

set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact
else
  echo "warning: gitleaks not found; skipping staged secret scan" >&2
fi

# Only run fmt check if any Rust files are staged.
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$'; then
  echo "==> pre-commit: cargo fmt --all -- --check"
  cargo fmt --all -- --check || {
    echo "FAIL: rustfmt found issues. Run 'cargo fmt --all' to fix." >&2
    exit 1
  }
fi
